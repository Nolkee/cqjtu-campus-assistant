<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:paddingStart="11dp"
    android:paddingTop="10dp"
    android:paddingEnd="11dp"
    android:paddingBottom="9dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_widget_calendar" />

            <TextView
                android:id="@+id/widget_today_title"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="今日课表 · 第 1 周"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_count"
                android:layout_width="wrap_content"
                android:layout_height="19dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minWidth="42dp"
                android:text="共 4 节"
                android:textColor="#64748B"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_today_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="今日无课"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/widget_today_row_1"
            android:layout_width="match_parent"
            android:layout_height="27dp"
            android:layout_marginTop="5dp"
            android:background="@drawable/widget_today_row_normal"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_today_time_1"
                android:layout_width="46dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="08:20"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_accent_1"
                android:layout_width="4dp"
                android:layout_height="14dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/widget_accent_next"
                android:text="" />

            <TextView
                android:id="@+id/widget_today_course_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="概统B"
                android:textColor="#263241"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_meta_1"
                android:layout_width="108dp"
                android:layout_height="match_parent"
                android:ellipsize="end"
                android:gravity="center_vertical|end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="A01231"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_today_row_2"
            android:layout_width="match_parent"
            android:layout_height="27dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/widget_today_row_normal"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_today_time_2"
                android:layout_width="46dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="10:00"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_accent_2"
                android:layout_width="4dp"
                android:layout_height="14dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/widget_accent_next"
                android:text="" />

            <TextView
                android:id="@+id/widget_today_course_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="课程"
                android:textColor="#263241"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_meta_2"
                android:layout_width="108dp"
                android:layout_height="match_parent"
                android:ellipsize="end"
                android:gravity="center_vertical|end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="教室"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_today_row_3"
            android:layout_width="match_parent"
            android:layout_height="27dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/widget_today_row_normal"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_today_time_3"
                android:layout_width="46dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="14:00"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_accent_3"
                android:layout_width="4dp"
                android:layout_height="14dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/widget_accent_next"
                android:text="" />

            <TextView
                android:id="@+id/widget_today_course_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="课程"
                android:textColor="#263241"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_meta_3"
                android:layout_width="108dp"
                android:layout_height="match_parent"
                android:ellipsize="end"
                android:gravity="center_vertical|end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="教室"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_today_row_4"
            android:layout_width="match_parent"
            android:layout_height="27dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/widget_today_row_normal"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_today_time_4"
                android:layout_width="46dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="16:25"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_accent_4"
                android:layout_width="4dp"
                android:layout_height="14dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/widget_accent_next"
                android:text="" />

            <TextView
                android:id="@+id/widget_today_course_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="课程"
                android:textColor="#263241"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_today_meta_4"
                android:layout_width="108dp"
                android:layout_height="match_parent"
                android:ellipsize="end"
                android:gravity="center_vertical|end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="教室"
                android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_today_more"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:gravity="end|center_vertical"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="还有 1 节"
            android:textColor="#64748B"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_today_spacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <LinearLayout
            android:id="@+id/widget_action_bar"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/widget_action_card"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/widget_action_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="9dp"
                android:paddingEnd="9dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="校园卡"
                    android:textColor="#2563EB"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_action_card_balance"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="center_vertical|end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="未同步"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_action_electricity"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/widget_action_background_warm"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="9dp"
                android:paddingEnd="9dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="电费"
                    android:textColor="#B45309"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_action_electricity_balance"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="center_vertical|end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="未同步"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
